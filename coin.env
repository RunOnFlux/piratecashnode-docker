# Coin-specific config for the Flux HA masternode template.
# The generic scripts are identical across coins; only this file changes per coin.
# All values verified against piratecash/piratecash source (Dash v21 base — see README).
COIN_TICKER="PIRATE"
COIN_DAEMON="piratecashd"                # configure.ac:22 (BITCOIN_DAEMON_NAME)
COIN_CLI_BIN="piratecash-cli"            # configure.ac:24 (BITCOIN_CLI_NAME)
DATADIR="/root/.piratecore"             # default dir .piratecore (util/system.cpp:857) — NOT .piratecash
CONF="${DATADIR}/piratecash.conf"       # BITCOIN_CONF_FILENAME (util/system.cpp:96)
MN_PORT=63636                           # CMainParams nDefaultPort (chainparams.cpp:308)
BLS_PARAM="masternodeblsprivkey"        # init.cpp:785 — PirateCash keeps Dash's MASTERNODE key name
SEED_NODES=""
CLI="${COIN_CLI_BIN} -datadir=${DATADIR} -conf=${CONF}"
